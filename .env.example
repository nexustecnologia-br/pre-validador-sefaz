# === NODE ===
NODE_ENV=development
PORT=3000

# === DATABASE ===
DATABASE_URL=postgresql://postgres:postgrespass123@localhost:5432/validador_sefaz
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# === REDIS ===
REDIS_URL=redis://localhost:6379

# === JWT ===
JWT_SECRET=seu-secret-muito-seguro-aqui-mude-em-producao
JWT_EXPIRE_IN=24h
JWT_REFRESH_EXPIRE_IN=30d

# === SEFAZ ===
SEFAZ_ENDPOINT=https://nfe.sefaz.rs.gov.br/webservices
SEFAZ_TIMEOUT_MS=5000
SEFAZ_CACHE_TTL_HOURS=24

# === LOGS ===
LOG_LEVEL=debug
LOG_FORMAT=json

# === CORS ===
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:3001

# === SUPABASE (alternativa a PostgreSQL local) ===
# SUPABASE_URL=https://seu-project.supabase.co
# SUPABASE_ANON_KEY=seu-anon-key
# SUPABASE_SERVICE_ROLE_KEY=seu-service-role-key

# === SENTRY (error tracking) ===
# SENTRY_DSN=https://seu-sentry-dsn@sentry.io/project-id

# === S3 (para armazenar backup XMLs) ===
