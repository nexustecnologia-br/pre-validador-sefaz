{
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/validar.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "api/_tables.json"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/validar",
      "dest": "/api/validar.ts"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.+)",
      "dest": "/index.html"
    }
  ]
}
