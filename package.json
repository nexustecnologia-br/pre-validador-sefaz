{
  "name": "pre-validador-sefaz",
  "version": "1.0.0",
  "description": "Sistema de pré-validação de notas fiscais antes da SEFAZ-RS",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node-esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "npm run db:migrate && npm run db:seed",
    "db:migrate": "node -e \"require('child_process').execSync('psql $DATABASE_URL < config/schema.sql', {stdio: 'inherit'})\"",
    "db:seed": "ts-node-esm config/seed.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "cypress run",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'frontend/src/**/*.{ts,tsx}'",
    "queue:worker": "ts-node-esm src/queue-worker.ts",
    "load-test": "k6 run tests/load/validation-load-test.js",
    "load-test:apache": "bash tests/load/apache-bench-test.sh",
    "docker:build": "docker build -t validador-sefaz .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "cache:clear": "ts-node-esm -e \"const {getCacheService} = require('./src/services/CacheService'); getCacheService().clear()\""
  },
  "keywords": [
    "SEFAZ",
    "validação",
    "NF-e",
    "XML",
    "fiscal"
  ],
  "author": "Rodrigo Rafael",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6",
    "bcrypt": "^5.1",
    "bull": "^4.10",
    "cors": "^2.8",
    "dotenv": "^16.0",
    "express": "^4.18",
    "express-rate-limit": "^6.7",
    "helmet": "^7.0",
    "joi": "^17.0",
    "jsonwebtoken": "^9.0",
    "pg": "^8.10",
    "redis": "^4.6",
    "swagger-jsdoc": "^6.2",
    "swagger-ui-express": "^5.0",
    "typeorm": "^0.3",
    "uuid": "^9.0",
    "winston": "^3.10",
    "xml2js": "^0.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.10.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "cypress": "^13.6.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
